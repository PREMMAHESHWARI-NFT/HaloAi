# Environment variables for HaloAI Desktop

# Primary LLM: Z.ai GLM-5.1
# Get your Z.ai API key from: https://z.ai/
VITE_ZAI_API_KEY=

# Fallback LLM: Groq (used when Z.ai is unavailable)
# Get your Groq API key from: https://console.groq.com/
VITE_GROQ_API_KEY=

# Get your Deepgram API key from: https://deepgram.com/
VITE_DEEPGRAM_API_KEY=your_deepgram_api_key_here

VITE_OPENROUTER_API_KEY=